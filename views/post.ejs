<%- include('partials/header') %>

<a href="/" class="back-link">← 返回首页</a>

<article class="post-detail">
  <header class="post-header">
    <h1><%= post.title %></h1>
    <div class="post-meta">
      <span class="author"><a href="/user/<%= encodeURIComponent(post.author_name) %>"><%= post.author_name %></a></span>
      <span class="post-meta-dot"></span>
      <span><%= new Date(post.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      <span class="post-meta-dot"></span>
      <span><%= post.views %> 次阅读</span>
      <span class="post-meta-dot"></span>
      <span><%= likesCount %> 点赞</span>
    </div>

    <div class="post-like-actions">
      <% if (currentUser) { %>
        <% if (likedByCurrentUser) { %>
          <form action="/posts/<%= post.id %>/likes?_method=DELETE" method="POST" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-like btn-like--active">已点赞</button>
          </form>
        <% } else { %>
          <form action="/posts/<%= post.id %>/likes" method="POST" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-outline btn-like">点赞</button>
          </form>
        <% } %>
      <% } else { %>
        <a href="/auth/login" class="btn btn-outline btn-like">登录后点赞</a>
      <% } %>
    </div>

    <% if (post.tags) { %>
      <div class="post-tags" style="margin-top: 14px;">
        <% post.tags.split(',').forEach(function(t) { %>
          <% if (t.trim()) { %>
            <a href="/?tag=<%= t.trim() %>" class="tag"># <%= t.trim() %></a>
          <% } %>
        <% }) %>
      </div>
    <% } %>
  </header>

  <div class="post-content">
    <%- post.htmlContent %>
  </div>

  <% if (currentUser && currentUser.id === post.author_id) { %>
    <div class="post-actions">
      <a href="/posts/<%= post.id %>/edit" class="btn btn-outline">编辑文章</a>
      <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('确定要删除这篇文章吗？')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-danger">删除文章</button>
      </form>
    </div>
  <% } %>
</article>

<section class="comments-section">
  <div class="comments-header">
    评论
    <span class="comments-count"><%= commentsCount %></span>
  </div>

  <p class="login-hint">当前站点已关闭评论功能，普通用户仅支持浏览与点赞。</p>

  <% if (commentsCount === 0) { %>
    <p class="no-comments">暂无评论</p>
  <% } else { %>
    <div class="comments-list">
      <% comments.forEach(function(comment) { %>
        <%- include('partials/comment-item', { comment: comment, post: post }) %>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
