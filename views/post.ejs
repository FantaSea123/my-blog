<%- include('partials/header') %>

<article class="post-detail">
  <header class="post-header">
    <h1><%= post.title %></h1>
    <div class="post-meta">
      <span>👤 <%= post.author_name %></span>
      <span>📅 <%= new Date(post.created_at).toLocaleDateString('zh-CN') %></span>
      <span>👁 <%= post.views %> 次阅读</span>
    </div>
    <% if (post.tags) { %>
      <div class="post-tags">
        <% post.tags.split(',').forEach(function(t) { %>
          <% if (t.trim()) { %>
            <a href="/?tag=<%= t.trim() %>" class="tag">#<%= t.trim() %></a>
          <% } %>
        <% }) %>
      </div>
    <% } %>
  </header>

  <div class="post-content">
    <%- post.htmlContent %>
  </div>

  <% if (currentUser && currentUser.id === post.author_id) { %>
    <div class="post-actions">
      <a href="/posts/<%= post.id %>/edit" class="btn btn-primary">✏️ 编辑</a>
      <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="display:inline"
            onsubmit="return confirm('确定要删除这篇文章吗？')">
        <button type="submit" class="btn btn-danger">🗑 删除</button>
      </form>
    </div>
  <% } %>
</article>

<a href="/" class="back-link">← 返回首页</a>

<%- include('partials/footer') %>
