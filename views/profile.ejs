<%- include('partials/header') %>

<a href="/" class="back-link">← 返回首页</a>

<div class="profile-page">
  <div class="profile-card">
    <img src="/avatar/<%= encodeURIComponent(profileUser.username) %>" class="profile-avatar" alt="<%= profileUser.username %>">
    <div class="profile-info">
      <h1 class="profile-name"><%= profileUser.username %></h1>
      <p class="profile-bio"><%= profileUser.bio || '这个人很懒，什么都没写...' %></p>
      <div class="profile-stats">
        <span class="profile-stat">
          <strong><%= posts.length %></strong> 篇文章
        </span>
        <span class="profile-stat-dot"></span>
        <span class="profile-stat">
          加入于 <%= new Date(profileUser.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' }) %>
        </span>
      </div>
    </div>
  </div>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">✨</div>
      <h2>还没有文章</h2>
      <p>这位作者还没有发布任何内容</p>
    </div>
  <% } else { %>
    <div class="posts-grid">
      <% posts.forEach(function(post) { %>
        <article class="post-card">
          <div class="post-card-main">
            <div class="post-meta">
              <span><%= new Date(post.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            </div>
            <h2 class="post-title">
              <a href="/posts/<%= post.id %>"><%= post.title %></a>
            </h2>
            <p class="post-summary"><%= post.summary %></p>
            <% if (post.tags) { %>
              <div class="post-tags">
                <% post.tags.split(',').forEach(function(t) { %>
                  <% if (t.trim()) { %>
                    <a href="/?tag=<%= t.trim() %>" class="tag"># <%= t.trim() %></a>
                  <% } %>
                <% }) %>
              </div>
            <% } %>
          </div>
          <div class="post-card-side">
            <span class="post-views"><%= post.views %> 阅读</span>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
