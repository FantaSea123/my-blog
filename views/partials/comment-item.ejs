<div class="comment-item <%= comment.is_deleted ? 'comment-item--deleted' : '' %>" id="comment-<%= comment.id %>">
  <div class="comment-header">
    <a href="/user/<%= encodeURIComponent(comment.author_name) %>" class="comment-avatar-link">
      <img src="/avatar/<%= encodeURIComponent(comment.author_name) %>" class="comment-avatar" alt="<%= comment.author_name %>">
    </a>
    <a href="/user/<%= encodeURIComponent(comment.author_name) %>" class="comment-author"><%= comment.author_name %></a>
    <span class="comment-date"><%= new Date(comment.created_at).toLocaleDateString('zh-CN') %></span>
  </div>

  <div class="comment-body">
    <% if (comment.is_deleted) { %>
      <p class="comment-content comment-content--deleted">该评论已删除</p>
    <% } else { %>
      <p class="comment-content"><%= comment.content %></p>
    <% } %>

    <% if (comment.children && comment.children.length > 0) { %>
      <div class="comment-children">
        <% comment.children.forEach(function(child) { %>
          <%- include('comment-item', { comment: child, post: post }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>
